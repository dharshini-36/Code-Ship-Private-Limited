//10. simple calculation
const calc = (n1,n2,ope) => {
    if(ope == "+"){
        console.log(n1+n2);
    }
    if(ope == "-"){
        console.log(n1-n2);
    }
    if(ope == "*"){
        console.log(n1*n2);
    }
    if(ope == "/"){
        console.log(n1/n2);
    }
}
