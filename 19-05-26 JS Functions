//8. swap two numbers
let swap = (a,b) => {
    console.log("Before swap: " + a,b);
    
    let temp = a;
    a=b;
    b=temp;
    
    console.log("After Swap: " + a,b);
}
swap(3,7);
console.log("------------------------------------------------------");

