//2. check prime number
const checkprime = (n) => {
    if(n<=1){
        console.log(n+" is not a prime number");
    }
    if(n%1 == 0 && n%n == 0){
        console.log(n+ " is a prime number");
    }
    else{
        console.log(n + " is not a prime number");
    }
}
checkprime(3);
console.log("------------------------------------------------------");

